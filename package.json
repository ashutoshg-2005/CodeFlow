{
  "name": "codeflow",
  "version": "1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "dev:server": "bun run --hot packages/server/src/index.ts",
    "build:cli": "bun run --filter codeflow-ai build",
    "link:cli": "bun run build:cli && bun run scripts/link-cli.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
